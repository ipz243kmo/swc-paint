<Window x:Class="SWCPaint.Wpf.Views.Dialogs.NewProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новий проєкт" SizeToContent="WidthAndHeight" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="/Assets/Icons/paint-icon.png">

    <StackPanel Width="250" Margin="15">
        <TextBlock Text="Ширина (px):" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

        <TextBlock Text="Висота (px):" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

        <TextBlock Text="Колір фону:" Margin="0,0,0,5"/>

        <Button Command="{Binding ChangeColorCommand}" Height="30" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" BorderBrush="Black" BorderThickness="1">
                    <Rectangle Fill="{Binding BackgroundColor, Converter={StaticResource CoreColorToWpfBrushConverter}}"/>
                </Border>
                <TextBlock Text=" Обрати колір..." VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Button>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Створити" IsDefault="True" Width="80" Click="Accept_Click" Margin="0,0,10,0"/>
            <Button Content="Скасувати" IsCancel="True" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>