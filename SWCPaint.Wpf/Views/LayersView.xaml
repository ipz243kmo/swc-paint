<UserControl x:Class="SWCPaint.Wpf.Views.LayersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Background="#F8F9FA">

    <UserControl.Resources>
        <Style x:Key="LayerCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder" 
                                CornerRadius="6" 
                                BorderThickness="1.5" 
                                BorderBrush="#DEE2E6" 
                                Background="White"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="8,6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#ADB5BD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#0D6EFD"/>
                                <Setter TargetName="OuterBorder" Property="Background" Value="#F8F9FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#E9ECEF" Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#DEE2E6">
            <TextBlock Text="ШАРИ" FontWeight="Bold" Foreground="#495057" FontSize="11"/>
        </Border>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Layers}" 
                 SelectedItem="{Binding SelectedLayer}"
                 ItemContainerStyle="{StaticResource LayerCardStyle}"
                 BorderThickness="0" 
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel LastChildFill="True">
                        <CheckBox IsChecked="{Binding IsVisible}" VerticalAlignment="Center" Margin="0,0,8,0">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <TextBlock x:Name="Eye" Text="👁" FontSize="14" Cursor="Hand"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="Eye" Property="Text" Value="✕"/>
                                            <Setter TargetName="Eye" Property="Opacity" Value="0.3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                        <TextBlock Text="{Binding Name}" 
                                   VerticalAlignment="Center" 
                                   FontSize="13" 
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="8" Background="White" BorderThickness="0,1,0,0" BorderBrush="#DEE2E6">
            <UniformGrid Columns="4">
                <Button Command="{Binding AddLayerCommand}" Margin="2" Padding="5" Background="#E3F2FD" BorderBrush="#BBDEFB">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontWeight="Bold" Margin="0,0,5,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RemoveLayerCommand}" Margin="2" Padding="5" Background="#FFEBEE" BorderBrush="#FFCDD2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="×" FontWeight="Bold" Margin="0,0,5,0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding MoveLayerUpCommand}" Margin="2" Padding="5" Background="#F0F4F8">
                    <TextBlock Text="↑" FontWeight="Bold"/>
                </Button>
                <Button Command="{Binding MoveLayerDownCommand}" Margin="2" Padding="5" Background="#F0F4F8">
                    <TextBlock Text="↓" FontWeight="Bold"/>
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>