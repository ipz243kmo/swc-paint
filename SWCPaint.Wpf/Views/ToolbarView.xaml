<UserControl x:Class="SWCPaint.Wpf.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignWidth="800">
    <ToolBarTray>
        <ToolBar>
            <Button Command="{Binding UndoCommand}" ToolTip="Відмінити (Ctrl+Z)">
                <Image Source="/Assets/Icons/undo.png" Width="16" Height="16" />
            </Button>
            <Button Command="{Binding RedoCommand}" ToolTip="Повторити (Ctrl+Y)">
                <Image Source="/Assets/Icons/redo.png" Width="16" Height="16" />
            </Button>

            <Separator />

            <ItemsControl ItemsSource="{Binding ToolInfos}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Style="{StaticResource {x:Static ToolBar.RadioButtonStyleKey}}"
                                     Command="{Binding DataContext.SelectToolCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     CommandParameter="{Binding Name}"
                                     ToolTip="{Binding DisplayName}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource ToolToBooleanConverter}" Mode="OneWay">
                                    <Binding Path="DataContext.CurrentTool" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    <Binding Path="Name"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <Image Source="{Binding IconPath}" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator />

            <Label Content="Кольори:" VerticalAlignment="Center"/>
            <Button Command="{Binding OpenColorPickerCommand}" CommandParameter="Stroke" ToolTip="Колір обводки">
                <Border Width="18" Height="18" BorderBrush="#333" BorderThickness="1">
                    <Rectangle Fill="{Binding Settings.StrokeColor, Converter={StaticResource CoreColorToWpfBrushConverter}}"/>
                </Border>
            </Button>

            <Button Command="{Binding OpenColorPickerCommand}" CommandParameter="Fill" ToolTip="Колір заливки">
                <Border Width="18" Height="18" BorderBrush="#333" BorderThickness="1">
                    <Rectangle Fill="{Binding Settings.FillColor, Converter={StaticResource CoreColorToWpfBrushConverter}}"/>
                </Border>
            </Button>

            <Separator />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                <Label Content="Товщина:" VerticalAlignment="Center"/>
                <Slider Width="100" 
                        Minimum="{Binding MinThickness}" 
                        Maximum="{Binding MaxThickness}" 
                        Value="{Binding Settings.Thickness}"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
                <StackPanel Orientation="Horizontal" Margin="5,0" Width="45">
                    <TextBlock Text="{Binding Settings.Thickness, StringFormat={}{0:F0}}" VerticalAlignment="Center"/>
                    <TextBlock Text=" px" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ToolBar>
    </ToolBarTray>
</UserControl>