<Application x:Class="SWCPaint.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SWCPaint.Wpf"
             xmlns:converters="clr-namespace:SWCPaint.Wpf.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <converters:CoreColorToWpfBrushConverter x:Key="CoreColorToWpfBrushConverter" />
        <converters:ToolToBooleanConverter x:Key="ToolToBooleanConverter" />
    </Application.Resources>
</Application>
