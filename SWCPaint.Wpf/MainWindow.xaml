<Window x:Class="SWCPaint.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SWCPaint.Wpf.Views"
        xmlns:vm="clr-namespace:SWCPaint.Wpf.ViewModels"
        xmlns:conv="clr-namespace:SWCPaint.Wpf.Converters"
        Title="Paint" Height="720" Width="1280" Icon="/Assets/Icons/paint-icon.png">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}" />
    </Window.InputBindings>
    
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Новий" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="Зберегти" Command="{Binding SaveProjectCommand}"/>
                <Separator />
                <MenuItem Header="Вихід" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Відмінити" Command="{Binding UndoCommand}"/>
                <MenuItem Header="Повторити" Command="{Binding RedoCommand}"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="{Binding UndoCommand}" ToolTip="Відмінити (Ctrl+Z)">
                    <Image Source="/Assets/Icons/undo.png" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding RedoCommand}" ToolTip="Повторити (Ctrl+Y)">
                    <Image Source="/Assets/Icons/redo.png" Width="16" Height="16" />
                </Button>

                <Separator />

                <ItemsControl ItemsSource="{Binding ToolInfos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Style="{StaticResource {x:Static ToolBar.RadioButtonStyleKey}}"
                         Command="{Binding DataContext.SelectToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                         CommandParameter="{Binding Name}"
                         ToolTip="{Binding DisplayName}">

                                <RadioButton.IsChecked>
                                    <MultiBinding Converter="{StaticResource ToolToBooleanConverter}" Mode="OneWay">
                                        <Binding Path="DataContext.CurrentTool" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Name"/>
                                    </MultiBinding>
                                </RadioButton.IsChecked>

                                <Image Source="{Binding IconPath}" Width="16" Height="16" />
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator />

                <Label Content="Кольори (Обводка/Заливка):"/>
                <ComboBox Width="120" 
                          ItemsSource="{Binding AvailableColors}" 
                          SelectedItem="{Binding SelectedStrokeColor}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="14" Height="14" Fill="{Binding Name}" Margin="0,0,5,0" Stroke="Black" StrokeThickness="0.5"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Width="120" 
                      ItemsSource="{Binding AvailableColors}" 
                      SelectedItem="{Binding SelectedFillColor}"> 
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="14" Height="14" Fill="{Binding Name}" Margin="0,0,5,0" Stroke="Black" StrokeThickness="0.5"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Separator />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                    <Label Content="Товщина:"/>
                    <Slider x:Name="ThicknessSlider" 
                            Width="100" 
                            Minimum="1" 
                            Maximum="20" 
                            Value="{Binding Settings.Thickness}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Value, ElementName=ThicknessSlider, StringFormat={}{0:F0}}" 
                               VerticalAlignment="Center" Margin="5,0,0,0" Width="20"/>
                    <TextBlock Text="px" VerticalAlignment="Center"/>
                </StackPanel>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Background="#333">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <Border Background="White" 
                        Width="{Binding Project.Width}" 
                        Height="{Binding Project.Height}"
                        Margin="40"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>

                    <views:DrawingCanvas Project="{Binding Project}" 
                                         ActiveTool="{Binding CurrentTool}" Margin="0,-20,0,20" />
                </Border>
            </ScrollViewer>

            <views:LayersView Grid.Column="1" 
                              DataContext="{Binding LayersContext}" 
                              VerticalAlignment="Stretch"
                              BorderThickness="1,0,0,0"
                              BorderBrush="#ADB5BD"/>
        </Grid>
    </DockPanel>
</Window>